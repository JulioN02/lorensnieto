{
  "name": "lorensnieto",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de Gestión Integral - Lorens Nieto",
  "workspaces": [
    "backend",
    "frontend-admin"
  ],
  "scripts": {
    "dev": "npm run dev:backend & npm run dev:admin",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:admin": "npm run dev --workspace=frontend-admin",
    "build": "npm run build --workspace=backend && npm run build --workspace=frontend-admin",
    "test": "npm run test --workspaces",
    "db:migrate": "npm run db:migrate --workspace=backend",
    "db:seed": "npm run db:seed --workspace=backend"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0"
  }
}
