// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  admin
  partner
}

enum PropertyType {
  casa_campo
  apartamento
}

enum ServiceClassification {
  alimentacion
  limpieza
  otros
}

enum LeadStatus {
  nueva
  revisada
  convertida
  descartada
}

enum ReservationStatus {
  pendiente
  confirmada
  en_servicio
  finalizada
  cancelada
}

enum PaymentType {
  abono
  total
}

enum PaymentStatus {
  pendiente
  pagado
}

enum PartnerPhase {
  fase_1
  fase_2
}

enum PartnerPeriodStatus {
  pendiente
  en_alerta
  pagado_parcial
  pagado
  en_disputa
}

enum MediaType {
  img
  video
}

enum EntityType {
  property
  service
}

// ============================================
// USER (Admin y Socio Técnico)
// ============================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      UserRole
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ============================================
// PROPERTY (Casas de Campo y Apartamentos)
// ============================================

model Property {
  id          String       @id @default(uuid())
  type        PropertyType
  name        String
  description String
  zone        String
  address     String
  capacity    Int
  rooms       Int?
  priceNight  Decimal      @map("price_night") @db.Decimal(10, 2)
  amenities   String[]
  rules       String[]
  active      Boolean      @default(true)
  ownerName   String       @map("owner_name")
  ownerCedula String       @map("owner_cedula")
  ownerPhone  String       @map("owner_phone")
  ownerEmail  String       @map("owner_email")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  media        Media[]
  leads        Lead[]
  reservations Reservation[]

  @@map("properties")
}

// ============================================
// SERVICE (Alimentación, Limpieza, Otros)
// ============================================

model Service {
  id             String               @id @default(uuid())
  name           String
  description    String
  classification ServiceClassification
  type           String
  price          Decimal              @db.Decimal(10, 2)
  rules          String[]
  active         Boolean              @default(true)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  media         Media[]
  leads         Lead[]
  contractings  ContractingService[]

  @@map("services")
}

// ============================================
// MEDIA (Imágenes y Videos de Propiedades y Servicios)
// ============================================

model Media {
  id         String     @id @default(uuid())
  entityType EntityType @map("entity_type")
  entityId   String     @map("entity_id")
  url        String
  mediaType  MediaType  @map("media_type")
  orderIndex Int        @default(0) @map("order_index")
  createdAt  DateTime   @default(now()) @map("created_at")

  property Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String? @map("property_id")

  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId String? @map("service_id")

  @@unique([entityType, entityId, url])
  @@map("media")
}

// ============================================
// LEAD (Solicitudes de Clientes)
// ============================================

model Lead {
  id                 String      @id @default(uuid())
  customerName       String      @map("customer_name")
  customerCedula     String      @map("customer_cedula")
  customerPhone      String      @map("customer_phone")
  customerEmail      String      @map("customer_email")
  dateInterest       DateTime?   @map("date_interest")
  additionalServices String[]    @map("additional_services")
  status             LeadStatus  @default(nueva)
  notes              String      @default("")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  propertyId String? @map("property_id")
  property   Property? @relation(fields: [propertyId], references: [id])

  serviceId String? @map("service_id")
  service   Service? @relation(fields: [serviceId], references: [id])

  leadNotes LeadNote[]

  // Inversa de relaciones desde Reservation y Contracting
  reservation Reservation?
  contracting  Contracting?

  @@map("leads")
}

// ============================================
// LEAD NOTE (Notas internas de la administradora)
// ============================================

model LeadNote {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_notes")
}

// ============================================
// RESERVATION
// ============================================

model Reservation {
  id                 String            @id @default(uuid())
  customerName       String            @map("customer_name")
  customerCedula     String            @map("customer_cedula")
  customerPhone      String            @map("customer_phone")
  customerEmail      String            @map("customer_email")
  dateStart          DateTime          @map("date_start")
  dateEnd            DateTime          @map("date_end")
  additionalServices String[]          @map("additional_services")
  priceTotal         Decimal           @map("price_total") @db.Decimal(12, 2)
  status             ReservationStatus @default(pendiente)
  observations       String            @default("")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  propertyId String  @map("property_id")
  property   Property @relation(fields: [propertyId], references: [id])

  payments Payment[]

  leadId String? @unique @map("lead_id")
  lead   Lead?   @relation(fields: [leadId], references: [id])

  contractingId String? @unique @map("contracting_id")
  contracting   Contracting? @relation(fields: [contractingId], references: [id])

  @@index([propertyId, dateStart, dateEnd])
  @@map("reservations")
}

// ============================================
// CONTRACTING (Contratación de Servicios)
// ============================================

model Contracting {
  id                 String            @id @default(uuid())
  customerName       String            @map("customer_name")
  customerCedula     String            @map("customer_cedula")
  customerPhone      String            @map("customer_phone")
  customerEmail      String            @map("customer_email")
  dateStart          DateTime          @map("date_start")
  dateEnd            DateTime          @map("date_end")
  priceTotal         Decimal           @map("price_total") @db.Decimal(12, 2)
  status             ReservationStatus @default(pendiente)
  observations       String            @default("")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  services ContractingService[]

  leadId String? @unique @map("lead_id")
  lead   Lead?   @relation(fields: [leadId], references: [id])

  reservation Reservation?

  @@map("contractings")
}

// ============================================
// CONTRACTING SERVICE (Servicios contratados dentro de una contratación)
// ============================================

model ContractingService {
  id            String @id @default(uuid())
  contractingId String @map("contracting_id")
  serviceId     String @map("service_id")
  price         Decimal @db.Decimal(10, 2)

  contracting Contracting @relation(fields: [contractingId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id])

  @@unique([contractingId, serviceId])
  @@map("contracting_services")
}

// ============================================
// PAYMENT (Pagos de una reserva)
// ============================================

model Payment {
  id            String        @id @default(uuid())
  reservationId String        @map("reservation_id")
  amount        Decimal       @db.Decimal(12, 2)
  type          PaymentType
  status        PaymentStatus @default(pendiente)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ============================================
// PARTNER PERIOD (Período de facturación del Socio Técnico)
// ============================================

model PartnerPeriod {
  id            String              @id @default(uuid())
  month         String              // YYYY-MM
  revenueTotal  Decimal             @map("revenue_total") @db.Decimal(14, 2)
  phase         PartnerPhase        @default(fase_1)
  pctApplied    Decimal             @map("pct_applied") @db.Decimal(5, 2)
  amountDue     Decimal             @map("amount_due") @db.Decimal(12, 2)
  amountPaid    Decimal             @default(0) @map("amount_paid") @db.Decimal(12, 2)
  status        PartnerPeriodStatus @default(pendiente)
  deadlineDate  DateTime           @map("deadline_date")
  paidAt        DateTime?           @map("paid_at")
  disputeNotes  String?             @map("dispute_notes")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  alerts AlertLog[]

  @@unique([month])
  @@map("partner_periods")
}

// ============================================
// ALERT LOG (Log de alertas automáticas)
// ============================================

model AlertLog {
  id            String   @id @default(uuid())
  periodId      String   @map("period_id")
  amountPending Decimal  @db.Decimal(12, 2) @map("amount_pending")
  triggeredAt   DateTime @default(now()) @map("triggered_at")
  resolvedAt    DateTime? @map("resolved_at")

  period PartnerPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@map("alert_logs")
}

// ============================================
// SETTINGS (Configuración global del sistema)
// ============================================

model Settings {
  id                  String   @id @default(uuid())
  commissionPct       Decimal  @default(0.10) @map("commission_pct") @db.Decimal(5, 4)
  rulesDocUrl         String   @default("") @map("rules_doc_url")
  notificationEmail   String   @default("") @map("notification_email")
  partnerDeadlineDays Int      @default(5) @map("partner_deadline_days")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
